{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*.stripe.com/*" }, { "url": "mailto:info@momentumminds.net" }]
    },
    "store:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.focusbox.net/*" },
        { "url": "http://localhost:8000/*" }
      ]
    },
    "updater:default",
    "process:default"
  ]
}
